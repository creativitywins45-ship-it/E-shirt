rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This rule allows only the authenticated user to read and write their own documents
    // within a collection named 'users' (or similar).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // You might also have other collections that are publicly readable or have different access patterns.
    // For example, a 'public_posts' collection where everyone can read but only authenticated users can create their own.
    // match /public_posts/{postId} {
    //   allow read: if true;
    //   allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
    //   allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    // }

    // If you have collections that should remain completely inaccessible or require more complex logic,
    // you can define separate match rules for them, or keep a general rule that denies access by default.
    match /{document=**} {
      allow read, write: if false; // Deny access to any other documents by default
    }
  }
}
